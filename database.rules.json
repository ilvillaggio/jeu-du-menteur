{
  "rules": {
    "orders": {
      ".read": true,
      ".indexOn": ["date"],
      "$orderId": {
        ".write": true
      }
    },
    "slots": {
      ".read": true,
      "$date": {
        "$slotKey": {
          ".write": true
        }
      }
    },
    "config": {
      ".read": true,
      "reservationsOpen": {
        ".write": true
      },
      "availability": {
        "$itemId": {
          ".write": true
        }
      },
      "stock": {
        "$itemId": {
          ".write": true
        }
      },
      "patons": {
        ".write": true,
        ".read": true
      }
    },
    "push_subscriptions": {
      ".read": true,
      "$subKey": {
        ".write": true
      }
    },
    "print_jobs": {
      ".read": true,
      ".write": true
    },
    "clients": {
      ".read": true,
      ".write": true
    },
    "claude_tasks": {
      ".read": true,
      ".write": true
    },
    "claude_deploys": {
      ".read": true,
      ".write": true
    }
  }
}
